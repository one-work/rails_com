<div data-controller="search-input" class="field has-addons mb-0">
  <div class="control">
    <%= search_field_tag key, params[key], class: 'input', placeholder: title, autocomplete: 'off', data: { action: 'input->search-input#cancel' }, form: 'filter_search_form' %>
  </div>
  <div class="control">
    <%= button_tag name: nil, disabled: true, data: { search_input_target: 'submit' }, form: 'filter_search_form', class: 'button is-info' do %>
      <%= svg_tag 'magnifying-glass', class: 'icon' %>
    <% end %>
  </div>
</div>
