<div>
  <div class="px-3 pb-3 has-block-space-between">
    <span class="size-7 has-border-left-primary">我的门店</span>
    <%= link_to({ controller: 'org/board/organs' }) do %>
      <%= svg_tag 'chevron-right' %>
    <% end %>
  </div>
  <div class="fixed-grid has-2-cols as-boxed p-3">
    <div class="grid">
      <%= link_to({ controller: 'org/board/organs' }, class: 'cell has-column-centered') do %>
        <p class="size-4"><%= current_user.counters['owned'].to_i %></p>
        <p class="size-7 text-grey">我创建的</p>
      <% end %>
      <%= link_to({ controller: 'org/board/organs' }, class: 'cell has-column-centered') do %>
        <p class="size-4"><%= current_user.counters['joined'].to_i %></p>
        <p class="size-7 text-grey">我加入的</p>
      <% end %>
    </div>
  </div>
</div>
