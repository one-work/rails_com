<div class="card as-transparent">
  <div class="card-header">
    <div class="size-7 text-grey has-border-left-primary">用户身份</div>
  </div>
  <div class="card-content fixed-grid has-3-cols">
    <div class="grid">
      <% if request.variant.include?(:mini_program) %>
        <div
          data-controller="mini-program"
          data-mini-program-nav-value="true"
          data-mini-program-url-value="/pages/service/index"
          data-action="click->mini-program#link"
          class="cell has-column-centered"
        >
          <%= svg_tag 'headset', class: 'icon is-medium text-primary' %>
          <span class="size-7 text-grey mt-1">联系客服</span>
        </div>
      <% elsif Rails.application.credentials.kf.present? %>
        <%= link_to Rails.application.credentials.kf, rel: 'nofollow', class: 'cell has-column-centered' do %>
          <%= svg_tag 'headset', class: 'icon is-medium text-primary' %>
          <span class="size-7 text-grey mt-1">联系客服</span>
        <% end %>
      <% end %>
      <%= link_to({ controller: 'ship/board/addresses' }, class: 'cell has-column-centered') do %>
        <%= svg_tag 'location-dot', class: 'icon is-medium text-primary' %>
        <div class="text-grey size-7 mt-1"><%= t('ship.board.addresses.index.title') %></div>
      <% end if defined? RailsShip %>
      <%= link_to({ controller: 'wechat/board/users', action: 'invite_qrcode' }, class: 'cell has-column-centered') do %>
        <div class="text-primary left-badge">
          <%= svg_tag 'qrcode', class: 'icon is-medium' %>
          <span class="tag is-badge is-danger">邀请有礼</span>
        </div>
        <div class="text-grey size-7 mt-1">邀请好友</div>
      <% end if defined? RailsWechat %>
    </div>
  </div>
</div>