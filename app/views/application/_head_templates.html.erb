<template id="template_tr_action">
  <form class="button_to" method="post">
    <button class="button is-small is-borderless" type="submit">
      <svg class="icon is-small">
        <use href="<%= asset_path 'icons_light.svg', host: "#{request.host_with_port}/#{Rails.app.config.relative_url_root}" %>"></use>
      </svg>
      <span></span>
    </button>
  </form>
</template>
<template id="template_tr_link">
  <a class="button is-small is-borderless">
    <svg class="icon is-small text-info">
      <use href="<%= asset_path 'icons_light.svg', host: "#{request.host_with_port}/#{Rails.app.config.relative_url_root}" %>"></use>
    </svg>
    <span></span>
  </a>
</template>
