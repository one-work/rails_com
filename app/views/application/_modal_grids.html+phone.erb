<div id="modal_grids" data-controller="modal" class="modal is-mobile is-mobile-bottom is-active">
  <div data-action="click->modal#close" class="modal-background has-animate-fade-in"></div>
  <div class="modal-card has-animate-slide-up">
    <section id="modal-card-body" class="modal-card-body">
      <div class="fixed-grid has-3-cols">
        <div class="grid gap-2 as-actions">
          <%= yield %>
        </div>
      </div>
    </section>
    <footer class="modal-card-foot">
      <div class="button is-borderless is-fullwidth text-grey" data-action="click->modal#close">取消</div>
    </footer>
  </div>
</div>
