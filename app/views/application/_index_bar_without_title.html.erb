<nav class="level is-narrow">
  <div class="level-left">
    <% if instance_variable_defined?(:@filter_columns) %>
      <%= render partial: 'filter_form/filter_extend', locals: { record_class: model_klass, keys: @filter_columns.pluck(:column_name) } %>
    <% end %>
  </div>
  <div class="level-right">
    <%= render partial: 'filter_per', locals: { models: instance_variable_get("@#{pluralize_model_name}") } if instance_variable_defined? "@#{pluralize_model_name}" %>
  </div>
</nav>
