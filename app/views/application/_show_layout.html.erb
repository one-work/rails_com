<dl class="as-show is-striped">
  <div>
    <dt>ID</dt>
    <dd>
      <div data-controller="clipboard">
        <span data-clipboard-target="source"><%= model.id %></span>
        <span data-action="click->clipboard#copy" class="tag is-badge is-danger">复制</span>
        <div data-clipboard-target="toast" class="tag is-badge is-success display-none">
          <%= svg_tag 'check' %>
        </div>
      </div>
    </dd>
  </div>
  <%= yield %>
  <% if model.respond_to? :created_at %>
  <div>
    <dt>添加时间</dt>
    <dd><time data-controller="time" data-format="human"><%= model.created_at.to_fs(:iso8601) %></time></dd>
  </div>
  <% end %>
  <% if model.respond_to? :updated_at %>
  <div>
    <dt>更新时间</dt>
    <dd><time data-controller="time" data-format="human"><%= model.updated_at.to_fs(:iso8601) %></time></dd>
  </div>
  <% end %>
</dl>
