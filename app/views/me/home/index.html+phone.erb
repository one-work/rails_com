<% if defined?(current_organ) && current_organ %>
  <%= render 'index_summary_organ' %>
<% else %>
  <%= render 'index_summary' %>
<% end %>

<div class="card as-transparent">
  <div class="card-header">
    <div>
      <span class="size-7 text-grey has-border-left-primary">常用功能</span>
    </div>
    <%= link_to({ controller: 'admin/home' }) do %>
      <%= svg_tag 'up-right-and-down-left-from-center' %>
      <span class="size-7">更多功能</span>
    <% end %>
  </div>
  <div class="card-content fixed-grid has-3-cols">
    <div class="grid">
      <%= render 'common_nav' %>
    </div>
  </div>
</div>

<div class="card as-transparent">
  <div class="card-header">
    <span class="size-7 text-grey has-border-left-primary">门店管理</span>
  </div>
  <div class="card-content fixed-grid has-3-cols">
    <div class="grid">
      <% if defined?(current_organ) && current_organ %>
        <%= link_to({ controller: 'factory/productions', host: current_organ.host }, class: 'cell has-column-centered') do %>
          <%= svg_tag 'up-right-and-down-left-from-center', class: 'icon is-medium text-primary' %>
          <span class="size-7 text-grey mt-1">门店预览</span>
        <% end if @roled_tabs.include?('/factory/productions') %>
        <%= link_to({ controller: 'factory/productions', action: 'swift', host: current_organ.host }, class: 'cell has-column-centered') do %>
          <%= svg_tag 'up-right-and-down-left-from-center', class: 'icon is-medium text-primary' %>
          <span class="size-7 text-grey mt-1">快捷下单预览</span>
        <% end if @roled_tabs.include?('/factory/productions/swift') %>
        <div
          data-controller="mini-program"
          data-mini-program-nav-value="true"
          data-mini-program-url-value="/pages/jump/index"
          data-mini-program-data-value="<%= @share.to_json %>"
          data-action="click->mini-program#link"
          class="cell has-column-centered"
        >
          <%= svg_tag 'share', class: 'icon is-medium text-primary' %>
          <span class="size-7 text-grey mt-1">分享门店</span>
        </div>
      <% end %>
      <%= link_to({ controller: 'factory/admin/organs', action: 'show' }, class: 'cell has-column-centered') do %>
        <%= svg_tag 'shop', class: 'icon is-medium text-primary' %>
        <span class="size-7 text-grey mt-1">门店设置</span>
      <% end %>
      <%= link_to({ controller: 'wechat/admin/registers', action: 'new' }, class: 'cell has-column-centered') do %>
        <%= image_tag 'icons/wxpay.svg', class: 'icon is-medium' %>
        <span class="size-7 text-grey mt-1">微信支付</span>
      <% end %>
      <%= link_to({ controller: 'print/admin/home' }, class: 'cell has-column-centered') do %>
        <div class="text-primary">
          <%= svg_tag 'bluetooth', class: 'icon is-medium' %>
        </div>
        <div class="size-7 text-grey mt-1">
          <p><%= t('print.admin.home.index.title') %></p>
        </div>
      <% end %>
    </div>
  </div>
</div>

<%= render 'powered_by' %>
