<%= link_to({ controller: 'org/partner/organs', host: "partner.#{Rails.app.routes.default_url_options[:host]}" }, class: 'media as-me px-4 py-3') do %>
  <div class="media-left">
  <% if current_organ.logo.attached? %>
    <%= image_tag current_organ.logo.variant(resize_to_limit: [64, 64]), class: 'image is-64x64 is-radius' %>
  <% else %>
    <div class="is-avatar">
      <div class="text"><%= current_organ.name[0] %></div>
    </div>
  <% end %>
  </div>
  <div class="media-content">
    <p class="text-weight-normal text-white">
      <strong><%= current_organ.name %></strong>
      <% if current_organ.dispatch %>
        <span class="tag is-primary is-light size-7"><%= current_organ.dispatch_i18n %></span>
      <% end %>
      <% if current_organ.mock_cache && current_organ.mock_cache.roles_arr.present? %>
        <div class="tags">
        <% current_organ.mock_cache.roles_arr.each do |role_str| %>
          <span class="tag is-info is-light size-7"><%= role_str %></span>
        <% end %>
        </div>
      <% end %>
    </p>
    <div class="size-7 text-white">
      <span><%= current_member.name %></span>
      <div class="tags are-small has-addons size-7 display-inline-flex">
        <span class="tag is-dark">管理</span>
        <span class="tag"><%= current_member.organ.name %></span>
      </div>
    </div>
  </div>
  <div class="media-right text-white">
    <span>返回列表</span>
    <%= svg_tag 'chevron-right', class: 'icon is-small' %>
  </div>
<% end %>
