<div class="grid">
<% meta_controller.actions.each do |meta_action| %>
  <% if @role.role_hash.fetch(meta_action.controller_path, []).include?(meta_action.action_name) %>
    <%= button_to({ action: 'action_off' }, params: { meta_action_id: meta_action.id }, method: :patch, form: { class: 'cell' }) do %>
      <%= svg_tag 'square-check' %>
      <span aria-label="<%= meta_action.action_name %>" class="text-grey"><%= meta_action.name %></span>
    <% end %>
  <% else %>
    <%= button_to({ action: 'action_on' }, params: { meta_action_id: meta_action.id }, method: :patch, form: { class: 'cell' }) do %>
      <%= svg_tag 'square' %>
      <span aria-label="<%= meta_action.action_name %>" class="text-grey"><%= meta_action.name %></span>
    <% end %>
  <% end %>
<% end %>
</div>
