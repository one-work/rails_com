<%= form_with theme: 'modal', model: @subscription, url: { action: 'create', **request.GET.slice(:shard) } do |f| %>
  <%= render 'modal_header' %>
  <section class="modal-card-body">
    <p><%= params[:shard] %></p>
    <%= f.text_field :subname %>
    <%= f.text_field :host %>
    <%= f.text_field :port, value: 5432 %>
    <%= f.text_field :dbname %>
    <%= f.text_field :user, value: 'postgres' %>
    <%= f.text_field :password, value: 'postgres' %>
    <%= f.text_field :pubname %>
  </section>
  <%= f.submit %>
<% end %>
