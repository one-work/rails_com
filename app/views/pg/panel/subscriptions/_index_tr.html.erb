<%=
  tr_tag(
    model,
    {
      action: url_for(action: 'refresh', id: model.id),
      icon: 'rotate',
      title: t('.refresh.title')
    },
    {
      href: url_for(controller: 'stat_subscriptions', pg_subscription_id: model.id),
      icon: 'list',
      title: t('.stat_subscriptions.index.title')
    }
  ) { yield }
%>
