<!DOCTYPE html>
<html lang="<%= I18n.locale %>" data-theme="light">
  <head>
    <%= render 'head_title' %>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
    <meta name="turbo-cache-control" content="no-preview">
    <meta name="turbo-prefetch" content="false">
    <meta name="turbo-refresh-method" content="morph">
    <meta name="turbo-refresh-scroll" content="preserve">
    <%= yield :reload %>
    <script
      src="https://res.wx.qq.com/open/js/jweixin-1.6.0.js"
      referrerpolicy="origin"
      data-turbo-track="reload"
      id="weixin_script"
      data-url="<%= url_for(controller: 'wechat', action: 'js') %>"
      async
    ></script>
    <%= javascript_include_tag 'wx', 'data-turbo-track': 'reload' %>
    <%= javascript_include_tag 'application', 'data-turbo-track': 'reload' %>
    <%= stylesheet_link_tag 'phone', media: 'all', 'data-turbo-track': 'reload', as: 'style' %>
    <% if request.variant.include?(:mini_program) %>
      <%= stylesheet_link_tag 'mini-program', media: 'all', 'data-turbo-track': 'reload', as: 'style' %>
    <% end %>
    <%= render 'head_extra_js' %>
    <%= csrf_meta_tags %>
    <%= action_cable_meta_tag %>
    <%= csp_meta_tag %>
  </head>
  <body>
    <%= render 'mini_program_message' %>
    <%= yield %>
  </body>
</html>
