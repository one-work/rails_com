<% if referer_eql?(controller_path, 'index') %>
  <%=
    turbo_stream.replace(
      "tr_#{params[:id]}",
      partial: 'index_item',
      layout: 'index_item_actions',
      locals: {
        model: defined?(model) ? model : instance_variable_get("@#{model_name}")
      }
    )
  %>
  <%= turbo_stream.remove 'modal_form' %>
<% elsif referer_eql?(controller_path, 'edit') %>
  <%=
    turbo_stream.replace(
      'box',
      partial: 'show',
      locals: {
        model: defined?(model) ? model : instance_variable_get("@#{model_name}")
      }
    )
  %>
<% elsif referer_eql?(controller_path, 'show') %>
  <%=
    turbo_stream.replace(
      'box',
      partial: 'show',
      locals: {
        model: defined?(model) ? model : instance_variable_get("@#{model_name}")
      }
    )
  %>
  <%= turbo_stream.remove 'modal_form' %>
<% else %>
  <%= turbo_stream.visit %>
<% end %>
